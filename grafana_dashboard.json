    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "reqps"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 0,
        "y": 0
      },
      "id": 1,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "sum(rate(goshrt_http_requests_total[5m]))",
          "interval": "",
          "legendFormat": "Total Requests",
          "refId": "A"
        }
      ],
      "title": "HTTP Requests per Second",
      "type": "timeseries"
    },
    {
      "datasource": "Prometheus",
      "fieldConfig": {
        "defaults": {
          "unit": "seconds"
        },
        "overrides": []
      },
      "gridPos": {
        "h": 8,
        "w": 12,
        "x": 12,
        "y": 0
      },
      "id": 2,
      "options": {
        "legend": {
          "displayMode": "list",
          "placement": "bottom"
        }
      },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(goshrt_http_request_duration_seconds_bucket[5m])) by (le))",
          "interval": "",
          "legendFormat": "P95 Latency",
          "refId": "A"
        }
      ],
      "title": "Request Latency (P95)",
      "type": "timeseries"
    },
